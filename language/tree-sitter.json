{
  "grammars": [
    {
      "name": "mystra",
      "camelcase": "Mystra",
      "scope": "source.mystra",
      "path": ".",
      "file-types": [
        "tsl"
      ]
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tree-sitter grammar for Mystra",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-mystra"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
