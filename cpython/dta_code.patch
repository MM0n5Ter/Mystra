diff --git a/Modules/_taintmodule.c b/Modules/_taintmodule.c
new file mode 100644
index 0000000..3cc7881
--- /dev/null
+++ b/Modules/_taintmodule.c
@@ -0,0 +1,98 @@
+#include "Python.h"
+#include "pycore_pystate.h"
+#include "pycore_interp.h"
+#include "../Python/dta/cpython_dta_bridge.h"
+
+static inline void *
+_get_engine(PyThreadState *tstate)
+{
+    return tstate->interp->dta_taint_engine;
+}
+
+static PyObject *
+_taint_set_taint(PyObject *module, PyObject *args)
+{
+    PyObject *value;
+    const char *label = "Source";
+
+    if (!PyArg_ParseTuple(args, "O|s", &value, &label))
+        return NULL;
+
+    PyThreadState *tstate = _PyThreadState_GET();
+    void *engine = _get_engine(tstate);
+    if (engine == NULL) {
+        Py_INCREF(value);
+        return value;
+    }
+
+    uint32_t node_id = dta_create_source_node(engine, label);
+    dta_set_heap_taint(engine, (uintptr_t)value,
+                       DTA_ELEM_WILDCARD_KEY, node_id);
+
+    tstate->dta_shadow_acc = 0;
+
+    Py_INCREF(value);
+    return value;
+}
+
+static PyObject *
+_taint_get_taint(PyObject *module, PyObject *obj)
+{
+    PyThreadState *tstate = _PyThreadState_GET();
+    void *engine = _get_engine(tstate);
+    if (engine == NULL) {
+        return PyLong_FromLong(0);
+    }
+
+    uint32_t tid = dta_get_any_wildcard_taint(engine, (uintptr_t)obj);
+
+    tstate->dta_shadow_acc = 0;
+
+    return PyLong_FromLong((long)tid);
+}
+
+static PyObject *
+_taint_print_flow_tree(PyObject *module, PyObject *obj)
+{
+    PyThreadState *tstate = _PyThreadState_GET();
+    void *engine = _get_engine(tstate);
+    if (engine == NULL) {
+        Py_RETURN_NONE;
+    }
+
+    uint32_t tid = dta_get_any_wildcard_taint(engine, (uintptr_t)obj);
+    if (tid > 0) {
+        dta_print_flow_tree(engine, tid);
+    }
+
+    tstate->dta_shadow_acc = 0;
+
+    Py_RETURN_NONE;
+}
+
+static PyMethodDef _taint_methods[] = {
+    {"set_taint",       _taint_set_taint,       METH_VARARGS,
+     "set_taint(value, label='Source') -> value\n"
+     "Mark a value as a taint source. Returns the value unchanged."},
+    {"get_taint",       _taint_get_taint,       METH_O,
+     "get_taint(obj) -> int\n"
+     "Return the taint ID of an object (0 if clean)."},
+    {"print_flow_tree", _taint_print_flow_tree, METH_O,
+     "print_flow_tree(obj)\n"
+     "Print the taint flow tree to stderr."},
+    {NULL, NULL, 0, NULL}
+};
+
+static struct PyModuleDef _taintmodule = {
+    PyModuleDef_HEAD_INIT,
+    "_taint",
+    "Dynamic Taint Analysis introspection module",
+    -1,
+    _taint_methods,
+};
+
+PyMODINIT_FUNC
+PyInit__taint(void)
+{
+    return PyModule_Create(&_taintmodule);
+}
