+void TslInterpreter::DispatchHofExtract(
+    IVmAdapter& vm, TaintEngine* engine,
+    const BuiltinRuleDescriptor& hof_desc,
+    uintptr_t result_addr,
+    int matched_callback_arg_index)
+{
