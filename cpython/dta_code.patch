diff --git a/Python/dta/cpython_dta_bridge.cpp b/Python/dta/cpython_dta_bridge.cpp
new file mode 100644
index 0000000..c796331
--- /dev/null
+++ b/Python/dta/cpython_dta_bridge.cpp
@@ -0,0 +1,196 @@
+extern "C" {
+#include "Python.h"
+}
+#include "cpython_dta_bridge.h"
+#include "taint-core.h"
+#include "taint-summary.h"
+#include "taint-logger.h"
+#include "cpython_vm_adapter.h"
+#include <cstdio>
+#include <cstring>
+#include <vector>
+
+uintptr_t dynalysis::CPythonVmAdapter::GetParamRawValue(int arg_index) {
+    int idx = has_self_ ? arg_index : arg_index - 1;
+    if (idx < 0 || idx >= nargs_) return 0;
+    PyObject *obj = (PyObject *)arg_addrs_[idx];
+    if (obj && PyUnicode_Check(obj)) {
+        Py_hash_t h = PyObject_Hash(obj);
+        if (h == -1) { PyErr_Clear(); return 0; }
+        return (uintptr_t)h;
+    }
+    return 0;
+}
+
+uint64_t dynalysis::CPythonVmAdapter::GetStringContentHash(int arg_index) {
+    int idx = has_self_ ? arg_index : arg_index - 1;
+    if (idx < 0 || idx >= nargs_) return 0;
+    PyObject *obj = (PyObject *)arg_addrs_[idx];
+    if (obj && PyUnicode_Check(obj)) {
+        Py_ssize_t len = 0;
+        const char *s = PyUnicode_AsUTF8AndSize(obj, &len);
+        if (s == NULL) { PyErr_Clear(); return 0; }
+        /* FNV-1a 64-bit over the UTF-8 bytes — content-stable across processes. */
+        uint64_t h = 1469598103934665603ULL;
+        for (Py_ssize_t i = 0; i < len; i++) {
+            h ^= (uint64_t)(unsigned char)s[i];
+            h *= 1099511628211ULL;
+        }
+        return h;
+    }
+    return 0;
+}
+
+using dynalysis::TaintEngine;
+using dynalysis::FlowNode;
+using dynalysis::FlowNodeType;
+using dynalysis::ELEM_SHALLOW_KEY;
+using dynalysis::TslInterpreter;
+using dynalysis::TargetCategory;
+using dynalysis::CPythonVmAdapter;
+
+static CPythonVmAdapter g_vm_adapter;
+static bool g_rules_initialized = false;
+
+static inline TaintEngine* E(void *engine) {
+    return static_cast<TaintEngine*>(engine);
+}
+
+extern "C" {
+
+void* dta_engine_new(uint32_t *shadow_acc_ptr, uint32_t **shadow_frame_ptr) {
+    auto *engine = new TaintEngine(shadow_acc_ptr, shadow_frame_ptr);
+    auto *logger = new dynalysis::DtaLogger();
+    /* The shared-core logger is the single alert route. Always raise it to
+     * kAlert so every TSL SINK_CHECK emits: with DTA_JSON set it streams the
+     * structured {ts,cwe,sink,args,dag} JSONL to that file; otherwise it prints
+     * the human-readable "[ALERT] CWE-N | Sink: ..." line (+ DAG tree) to
+     * stderr in text mode. There is no separate hardcoded stderr path anymore. */
+    const char *dta_json = getenv("DTA_JSON");
+    logger->Init(dta_json, dynalysis::DtaLogger::Level::kAlert);
+    engine->set_logger(logger);
+    engine->EnableTracking();
+    dta_init_rules();
+    const auto *decls = TslInterpreter::GetVarDeclarations();
+    if (decls && !decls->empty()) {
+        engine->InitVarStore(*decls);
+    }
+    return engine;
+}
+
+void dta_engine_free(void *engine) {
+    if (engine) {
+        auto *logger = E(engine)->logger();
+        delete E(engine);
+        delete logger;
+    }
+}
+
+uint32_t dta_create_source_node(void *engine, const char *label) {
+    return E(engine)->CreateNode(label ? label : "Source");
+}
+
+uint32_t dta_create_derive_node(void *engine, const char *label, uint32_t parent1, uint32_t parent2) {
+    if (parent2 == 0) {
+        return E(engine)->CreateNode(label ? label : "Derive", parent1);
+    }
+    return E(engine)->CreateNode(label ? label : "Derive", parent1, parent2);
+}
+
+uint32_t dta_create_derive_node_multi(void *engine, const char *label, const uint32_t *parents, int count) {
+    std::vector<uint32_t> pvec(parents, parents + count);
+    return E(engine)->CreateNode(label ? label : "Derive", pvec);
+}
+
+uint32_t dta_create_transform_node(void *engine, const char *label, uint32_t parent) {
+    return E(engine)->CreateTransformNode(label ? label : "Transform", parent);
+}
+
+void dta_print_flow_tree(void *engine, uint32_t node_id) {
+    E(engine)->PrintFlowTree(node_id);
+}
+
+void dta_set_heap_taint(void *engine, uintptr_t obj_addr, uintptr_t field_key, uint32_t taint_id) {
+    E(engine)->SetHeapTaint(obj_addr, field_key, taint_id);
+}
+
+uint32_t dta_get_heap_taint(void *engine, uintptr_t obj_addr, uintptr_t field_key) {
+    return E(engine)->GetHeapTaint(obj_addr, field_key);
+}
+
+uint32_t dta_get_any_wildcard_taint(void *engine, uintptr_t obj_addr) {
+    return E(engine)->GetAnyWildcardTaint(obj_addr);
+}
+
+void dta_remove_heap_taint(void *engine, uintptr_t obj_addr) {
+    E(engine)->RemoveHeapTaint(obj_addr);
+}
+
+int dta_is_object_tracked(void *engine, uintptr_t obj_addr) {
+    return E(engine)->IsObjectTracked(obj_addr) ? 1 : 0;
+}
+
+uint32_t* dta_push_shadow_frame(void *engine, uintptr_t frame_ptr) {
+    return E(engine)->PushShadowFrame(frame_ptr);
+}
+
+uint32_t* dta_pop_shadow_frame(void *engine) {
+    return E(engine)->PopShadowFrame();
+}
+
+void dta_set_register_taint(void *engine, uintptr_t frame_ptr, int reg_idx, uint32_t taint_id) {
+    E(engine)->SetRegisterTaint(frame_ptr, reg_idx, taint_id);
+}
+
+uint32_t dta_get_register_taint(void *engine, uintptr_t frame_ptr, int reg_idx) {
+    return E(engine)->GetRegisterTaint(frame_ptr, reg_idx);
+}
+
+void dta_init_rules(void) {
+    if (!g_rules_initialized) {
+        g_rules_initialized = true;
+        TslInterpreter::EagerInitialize(g_vm_adapter);
+    }
+}
+
+int dta_tsl_has_rule(const char *signature) {
+    if (!g_rules_initialized) return 0;
+    return TslInterpreter::HasRulesForHostApi(signature ? signature : "") ? 1 : 0;
+}
+
+void dta_tsl_enter_call(void *engine, const char *signature,
+                        uintptr_t *arg_addrs, uint32_t *arg_taints, int nargs,
+                        int has_self) {
+    if (!g_rules_initialized) dta_init_rules();
+    TaintEngine *e = E(engine);
+    e->EnterCallFrame();
+    e->SetCurrentTargetSignature(TargetCategory::kHostApi, signature ? signature : "");
+    /* The shared-core interpreter follows the V8 convention: arg index 0 is the
+     * receiver (self), and real args start at index 1. All bound checks compare
+     * against an arg_count that INCLUDES that receiver slot. CPython PyCFunction
+     * module functions carry no self in their args, so the adapter shifts indices
+     * by -1 (see SetCallContext/has_self). To keep the interpreter's bound checks
+     * (rt_idx < arg_count) consistent with that shift, we must report the count
+     * WITH the phantom receiver slot, i.e. nargs + 1, when there is no self. */
+    e->SetArgMappingCount(has_self ? nargs : nargs + 1);
+    for (int i = 0; i < nargs && i < 32; i++) {
+        e->SetArgPhysicalAddr(i, arg_addrs[i]);
+    }
+    g_vm_adapter.SetCallContext(arg_addrs, arg_taints, nargs, has_self != 0);
+}
+
+void dta_tsl_pre_call(void *engine) {
+    if (!g_rules_initialized) return;
+    TslInterpreter::DispatchPreExecution(g_vm_adapter, E(engine));
+}
+
+uint32_t dta_tsl_post_call(void *engine, uintptr_t result_addr) {
+    if (!g_rules_initialized) return 0;
+    return TslInterpreter::DispatchAndApply(g_vm_adapter, E(engine), result_addr);
+}
+
+void dta_tsl_leave_call(void *engine) {
+    E(engine)->LeaveCallFrame();
+}
+
+}
