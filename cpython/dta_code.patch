+
+/* ================================================================
+ * DTA (Dynamic Taint Analysis) macros
+ * Used by bytecodes.c handlers to propagate taint through the
+ * shadow frame, shadow accumulator, and shadow heap.
+ * ================================================================ */
+
+#include "dta/cpython_dta_bridge.h"
+
+#define DTA_ENGINE() (tstate->interp->dta_taint_engine)
+
+#define DTA_ACC (tstate->dta_shadow_acc)
+
+#define DTA_SF (tstate->dta_shadow_frame)
+
+/* Shadow stack: mirrors CPython's value stack within the same shadow frame.
+ * localsplus[0..nlocalsplus-1] = locals, localsplus[nlocalsplus..] = stack.
+ * Shadow frame slot i corresponds to localsplus[i].
+ * DTA_STACK_IDX(ptr) converts a stack_pointer-relative address to a
+ * shadow frame index. */
+#define DTA_STACK_IDX(ptr) ((int)((ptr) - frame->localsplus))
+
+#define DTA_PUSH_STACK(val) do { \
+    if (DTA_SF) DTA_SF[DTA_STACK_IDX(stack_pointer)] = (val); \
+} while (0)
+
+#define DTA_PEEK_STACK(depth) \
+    (DTA_SF ? DTA_SF[DTA_STACK_IDX(stack_pointer - (depth))] : 0)
+
+#define DTA_PUSH_SHADOW_FRAME(fp) do { \
+    void *_dta_e = DTA_ENGINE(); \
+    if (_dta_e != NULL) { \
+        int _nlocals = _PyFrame_NumSlotsForCodeObject(_PyFrame_GetCode(fp)); \
+        DTA_SF = dta_push_shadow_frame(_dta_e, (uintptr_t)(fp)); \
+        (void)_nlocals; \
+    } \
+} while (0)
+
+#define DTA_POP_SHADOW_FRAME() do { \
+    void *_dta_e = DTA_ENGINE(); \
+    if (_dta_e != NULL) { \
+        DTA_SF = dta_pop_shadow_frame(_dta_e); \
+    } \
+} while (0)
+
+#define DTA_GET_LOCAL(idx) \
+    (DTA_SF ? DTA_SF[(idx)] : 0)
+
+#define DTA_SET_LOCAL(idx, val) do { \
+    if (DTA_SF) DTA_SF[(idx)] = (val); \
+} while (0)
+
+#define DTA_GET_HEAP_TAINT(obj) \
+    (DTA_ENGINE() ? dta_get_any_wildcard_taint(DTA_ENGINE(), (uintptr_t)(obj)) : 0)
+
+static inline int _dta_is_singleton(PyObject *obj) {
+    return _Py_IsImmortal(obj);
+}
+
+#define DTA_SET_HEAP_TAINT(obj, tid) do { \
+    void *_dta_e = DTA_ENGINE(); \
+    if (_dta_e != NULL && (tid) != 0 && !_dta_is_singleton((PyObject *)(obj))) { \
+        dta_set_heap_taint(_dta_e, (uintptr_t)(obj), DTA_ELEM_WILDCARD_KEY, (tid)); \
+    } \
+} while (0)
+
+#define DTA_GET_HEAP_TAINT_FIELD(obj, key) \
+    (DTA_ENGINE() ? dta_get_heap_taint(DTA_ENGINE(), (uintptr_t)(obj), (uintptr_t)(key)) : 0)
+
+#define DTA_SET_HEAP_TAINT_FIELD(obj, key, tid) do { \
+    void *_dta_e = DTA_ENGINE(); \
+    if (_dta_e != NULL && (tid) != 0) { \
+        dta_set_heap_taint(_dta_e, (uintptr_t)(obj), (uintptr_t)(key), (tid)); \
+    } \
+} while (0)
+
+#define DTA_REMOVE_HEAP_TAINT_FIELD(obj, key) do { \
+    void *_dta_e = DTA_ENGINE(); \
+    if (_dta_e != NULL) { \
+        dta_set_heap_taint(_dta_e, (uintptr_t)(obj), (uintptr_t)(key), 0); \
+    } \
+} while (0)
+
+#define DTA_BINARY_OP_MERGE_POST(_lt, _rt, res_obj) do { \
+    uint32_t _dta_merged = 0; \
+    if ((_lt) | (_rt)) { \
+        void *_dta_e = DTA_ENGINE(); \
+        if (_dta_e != NULL && !_dta_is_singleton((PyObject *)(res_obj))) { \
+            _dta_merged = dta_create_derive_node( \
+                _dta_e, "BinaryOp", (_lt), (_rt)); \
+            dta_set_heap_taint(_dta_e, (uintptr_t)(res_obj), \
+                               DTA_ELEM_WILDCARD_KEY, _dta_merged); \
+        } \
+    } \
+    DTA_ACC = _dta_merged; \
+    if (DTA_SF) DTA_SF[DTA_STACK_IDX(stack_pointer - 2)] = _dta_merged; \
+} while (0)
+
+/* ================================================================
+ * DTA Call Dispatch: classifier, pre-hook alert, post-hook propagate
+ * ================================================================ */
+
+#include "dta/cpython-taint-rules.h"
+
+static inline void
+_dta_classify_callee(PyObject *callable,
+                     const char **out_type, const char **out_func)
+{
+    *out_type = NULL;
+    *out_func = NULL;
+
+    if (PyCFunction_Check(callable)) {
+        PyCFunctionObject *cf = (PyCFunctionObject *)callable;
+        *out_func = cf->m_ml->ml_name;
+        if (cf->m_module != NULL && PyUnicode_Check(cf->m_module)) {
+            *out_type = PyUnicode_AsUTF8(cf->m_module);
+        } else if (cf->m_self != NULL) {
+            *out_type = Py_TYPE(cf->m_self)->tp_name;
+        }
+    } else if (Py_IS_TYPE(callable, &PyMethodDescr_Type)) {
+        PyMethodDescrObject *md = (PyMethodDescrObject *)callable;
+        *out_func = md->d_method->ml_name;
+        *out_type = md->d_common.d_type->tp_name;
+    } else if (PyType_Check(callable)) {
+        *out_func = ((PyTypeObject *)callable)->tp_name;
+        *out_type = "type";
+    }
+}
+
+/* Scan call arguments for taint. Uses shadow stack (via frame/stack_pointer)
+ * with heap taint fallback. Must be called from bytecode handler context. */
+#define _DTA_SCAN_CALL_ARGS(args, nargs, _out_taint) do { \
+    (_out_taint) = 0; \
+    void *_dta_e = DTA_ENGINE(); \
+    if (_dta_e != NULL) { \
+        for (int _i = 0; _i < (nargs); _i++) { \
+            uint32_t _t = DTA_GET_HEAP_TAINT((args)[_i]); \
+            if (_t != 0) { (_out_taint) = _t; break; } \
+        } \
+    } \
+} while (0)
+
+#define DTA_CALL_POST_HOOK(callable, res_obj, nargs_total) \
+    DTA_CALL_POST_HOOK_EX(callable, res_obj, nargs_total, \
+        !PyCFunction_Check((PyObject *)(callable)))
+
+#define DTA_CALL_POST_HOOK_EX(callable, res_obj, nargs_total, has_self) do { \
+    void *_dta_e = DTA_ENGINE(); \
+    if (_dta_e != NULL && (callable) != NULL) { \
+        const char *_dta_tn = NULL, *_dta_fn = NULL; \
+        _dta_classify_callee((callable), &_dta_tn, &_dta_fn); \
+        char _dta_sig[128]; \
+        if (_dta_tn && _dta_fn) \
+            snprintf(_dta_sig, sizeof(_dta_sig), "%s.%s", _dta_tn, _dta_fn); \
+        else if (_dta_fn) \
+            snprintf(_dta_sig, sizeof(_dta_sig), "%s", _dta_fn); \
+        else \
+            _dta_sig[0] = '\0'; \
+        /* Build arg addr/taint arrays for TSL dispatch */ \
+        int _dta_na = (nargs_total); \
+        if (_dta_na > 16) _dta_na = 16; \
+        uintptr_t _dta_addrs[16]; \
+        uint32_t _dta_taints[16]; \
+        for (int _i = 0; _i < _dta_na; _i++) { \
+            _dta_addrs[_i] = (uintptr_t)(args)[_i]; \
+            _dta_taints[_i] = DTA_GET_HEAP_TAINT((args)[_i]); \
+        } \
+        /* Enter call frame + set signature for TSL lookup */ \
+        dta_tsl_enter_call(_dta_e, _dta_sig, _dta_addrs, _dta_taints, _dta_na, (has_self)); \
+        /* Pre-hook: fires SINK_CHECK if rule matches */ \
+        dta_tsl_pre_call(_dta_e); \
+        /* Post-hook: always fire (SET rules need it even for None results). \
+         * Only apply PROPAGATE taint to non-singletons below. */ \
+        uint32_t _dta_rt = 0; \
+        int _dta_res_ok = ((res_obj) != NULL && \
+                           !_dta_is_singleton((PyObject *)(res_obj))); \
+        { \
+            uintptr_t _ra = _dta_res_ok ? (uintptr_t)(res_obj) : 0; \
+            _dta_rt = dta_tsl_post_call(_dta_e, _ra); \
+        } \
+        dta_tsl_leave_call(_dta_e); \
+        /* TSL SINK_CHECK (pre-hook) already fired any alert. If TSL returned 0 \
+         * (no propagating rule), fall back to the hardcoded CLEAR meta-op guard; \
+         * otherwise over-approximate with PassThrough propagation. */ \
+        if (_dta_rt == 0) { \
+            DtaRuleAction _dta_rule = dta_get_rule_action(_dta_tn, _dta_fn); \
+            if (_dta_rule.action == DTA_ACTION_CLEAR) { \
+                DTA_ACC = 0; \
+            } else { \
+                uint32_t _dta_at = 0; \
+                for (int _i = 0; _i < _dta_na && !_dta_at; _i++) \
+                    _dta_at = _dta_taints[_i]; \
+                if (_dta_at != 0 && _dta_res_ok) { \
+                    _dta_rt = dta_create_derive_node( \
+                        _dta_e, _dta_fn ? _dta_fn : "Call", _dta_at, 0); \
+                    dta_set_heap_taint(_dta_e, (uintptr_t)(res_obj), \
+                                       DTA_ELEM_WILDCARD_KEY, _dta_rt); \
+                    DTA_ACC = _dta_rt; \
+                } else { \
+                    DTA_ACC = 0; \
+                } \
+            } \
+        } else { \
+            if (_dta_res_ok) { \
+                dta_set_heap_taint(_dta_e, (uintptr_t)(res_obj), \
+                                   DTA_ELEM_WILDCARD_KEY, _dta_rt); \
+                DTA_ACC = _dta_rt; \
+            } else { \
+                DTA_ACC = 0; \
+            } \
+        } \
+    } \
+} while (0)
diff --git a/Python/dta/cpython-taint-rules.cpp b/Python/dta/cpython-taint-rules.cpp
