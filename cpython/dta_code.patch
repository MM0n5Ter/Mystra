@@ -0,0 +1,62 @@
+#include "cpython-taint-rules.h"
+#include <cstring>
+
+struct RuleEntry {
+    const char *type_name;
+    const char *func_name;
+    int action;
+    const char *cwe;
+};
+
+static const RuleEntry clear_rules[] = {
+    {NULL, "len",            DTA_ACTION_CLEAR, NULL},
+    {NULL, "__len__",        DTA_ACTION_CLEAR, NULL},
+    {NULL, "type",           DTA_ACTION_CLEAR, NULL},
+    {NULL, "id",             DTA_ACTION_CLEAR, NULL},
+    {NULL, "hash",           DTA_ACTION_CLEAR, NULL},
+    {NULL, "__hash__",       DTA_ACTION_CLEAR, NULL},
+    {NULL, "isinstance",     DTA_ACTION_CLEAR, NULL},
+    {NULL, "issubclass",     DTA_ACTION_CLEAR, NULL},
+    {NULL, "bool",           DTA_ACTION_CLEAR, NULL},
+    {NULL, "__bool__",       DTA_ACTION_CLEAR, NULL},
+    {NULL, "__eq__",         DTA_ACTION_CLEAR, NULL},
+    {NULL, "__ne__",         DTA_ACTION_CLEAR, NULL},
+    {NULL, "__lt__",         DTA_ACTION_CLEAR, NULL},
+    {NULL, "__le__",         DTA_ACTION_CLEAR, NULL},
+    {NULL, "__gt__",         DTA_ACTION_CLEAR, NULL},
+    {NULL, "__ge__",         DTA_ACTION_CLEAR, NULL},
+    {NULL, "__contains__",   DTA_ACTION_CLEAR, NULL},
+    {NULL, "repr",           DTA_ACTION_CLEAR, NULL},
+    {NULL, "__repr__",       DTA_ACTION_CLEAR, NULL},
+    {NULL, "print",          DTA_ACTION_CLEAR, NULL},
+    {"_taint", "set_taint",       DTA_ACTION_CLEAR, NULL},
+    {"_taint", "get_taint",       DTA_ACTION_CLEAR, NULL},
+    {"_taint", "print_flow_tree", DTA_ACTION_CLEAR, NULL},
+};
+
+/* NOTE: the hardcoded ALERT/sink table was removed. Sink detection is now owned
+ * entirely by the TSL SINK_CHECK rules (tsl/cpython-rules.tsl), dispatched by the
+ * shared-core interpreter and emitted through the DtaLogger (stderr text or JSONL
+ * DAG). Both the regular CALL post-hook and CALL_FUNCTION_EX route through TSL, so
+ * there is a single alert path. This table retains only the CLEAR meta-op fallback
+ * used when TSL has no rule for a callee — a defensive over-tainting guard, not a
+ * sink source. */
+
+static const int clear_count = sizeof(clear_rules) / sizeof(clear_rules[0]);
+
+extern "C"
+DtaRuleAction dta_get_rule_action(const char *type_name, const char *func_name) {
+    DtaRuleAction result = {DTA_ACTION_PROPAGATE, NULL};
+    if (func_name == NULL) return result;
+
+    for (int i = 0; i < clear_count; i++) {
+        if (clear_rules[i].type_name == NULL) {
+            if (strcmp(clear_rules[i].func_name, func_name) == 0) {
+                result.action = DTA_ACTION_CLEAR;
+                return result;
+            }
+        }
+    }
+
+    return result;
+}
