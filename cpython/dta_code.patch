+const BuiltinRuleDescriptor* TslInterpreter::GetBytecodePropertyStoreRule() {
+    return g_bytecode_property_store_rule;
+}
+
+const std::vector<VarDeclaration>* TslInterpreter::GetVarDeclarations() {
+    return g_var_declarations;
+}
